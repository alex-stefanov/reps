# --- Database ---------------------------------------------------------------
# Postgres connection string (Neon). Leave unset for local dev: the app falls
# back to an embedded PGlite database stored in .pglite/ (real Postgres, zero setup).
# DATABASE_URL=postgres://user:pass@host/db

# --- Auth (Auth.js) ----------------------------------------------------------
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=

# GitHub OAuth app (https://github.com/settings/developers)
# Callback URL: <origin>/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Dev-only sign-in (skips GitHub OAuth; enter any GitHub handle).
# Ignored in production builds. Used by local dev and Playwright.
# AUTH_DEV_MODE=true

# --- GitHub verification -----------------------------------------------------
# Optional token to raise the API rate limit (public_repo scope not required —
# verification only reads public events).
# GITHUB_TOKEN=

# Overridable API base — only for tests pointing at a mock server.
# GITHUB_API_URL=https://api.github.com

# --- Cron --------------------------------------------------------------------
# Shared secret protecting /api/sync (Vercel Cron sends it as a Bearer token).
# CRON_SECRET=
